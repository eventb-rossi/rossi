{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(CONTEXT|MACHINE|EVENTS|EVENT|INITIALISATION)\\b",
      "end": "^\\s*END\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(CONTEXT|MACHINE|EVENTS|EVENT|INITIALISATION|SETS|CONSTANTS|AXIOMS|THEOREMS|VARIABLES|INVARIANTS|VARIANT|REFINES|SEES|EXTENDS|ANY|WHERE|WHEN|WITH|WITNESS|THEN|BEGIN)\\b",
    "decreaseIndentPattern": "^\\s*END\\b"
  }
}
