{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "information_for_contributors": [
    "Generated by `rossi gen-grammars` from the canonical token tables. Do not edit by hand."
  ],
  "name": "Event-B",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#tokens_0"
    },
    {
      "include": "#tokens_1"
    },
    {
      "include": "#tokens_2"
    },
    {
      "include": "#tokens_3"
    },
    {
      "include": "#tokens_4"
    },
    {
      "include": "#tokens_5"
    },
    {
      "include": "#tokens_6"
    },
    {
      "include": "#tokens_7"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.eventb"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.eventb"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_']*",
          "name": "variable.other.eventb"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "match": "@[A-Za-z0-9_]+",
          "name": "entity.name.tag.eventb"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.eventb"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.eventb",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.eventb"
            }
          ]
        }
      ]
    },
    "tokens_0": {
      "match": "(?i)\\b(any|axioms|begin|constants|context|end|event|events|extends|initialisation|invariants|machine|refines|sees|sets|status|then|theorems|variables|variant|when|where|with|witness)\\b",
      "name": "keyword.control.eventb"
    },
    "tokens_1": {
      "match": "(?i)\\b(anticipated|convergent|ordinary|skip|theorem)\\b",
      "name": "keyword.other.eventb"
    },
    "tokens_2": {
      "match": "(в„•1|в„•|в„Ө|вҲ…|\\{\\})",
      "name": "constant.language.eventb"
    },
    "tokens_3": {
      "match": "(?i)\\b(bool|false|int|nat|nat1|true)\\b",
      "name": "constant.language.eventb"
    },
    "tokens_4": {
      "match": "\\b(card|finite|id|max|min|partition|pred|prj1|prj2|succ)\\b",
      "name": "support.function.eventb"
    },
    "tokens_5": {
      "match": "(<<->>|/<<:|:вҲҲ|:вҲЈ|<->>|<<->|>->>|в„ҷ1|\\+->|\\+>>|-->|->>|/<:|<->|<<:|<<\\||<=>|>\\+>|>->|\\|->|\\|>>|вҖҘ|в„ҷ|вҶ’|вҶ”|вҶ |вҶЈ|вҶҰ|вҮ’|вҮ”|вҮё|вҲҖ|вҲғ|вҲҲ|вҲү|вҲ’|вҲ–|вҲ—|вҲҳ|вҲЈ|вҲҘ|вҲ§|вҲЁ|вҲ©|вҲӘ|вҲј|вү”|вү |вүӨ|вүҘ|вҠӮ|вҠ„|вҠҶ|вҠҲ|вҠ—|вӢӮ|вӢғ|в–·|в—Ғ|вӨҖ|вӨ”|вӨ–|вҰӮ|в©Ө|в©Ҙ|о„Җ|о„Ғ|о„Ӯ|о„ғ|\\*\\*|\\.\\.|/:|/=|/\\\\|::|:=|:\\||<\\+|<:|<=|<\\||=>|><|>=|\\\\/|\\|>|\\|\\||В¬|В·|Г—|Г·|О»|!|#|%|&|\\*|\\+|-|\\.|/|:|;|<|=|>|\\\\|\\^|\\||~)",
      "name": "keyword.operator.eventb"
    },
    "tokens_6": {
      "match": "(?i)\\b(inter|union)\\b",
      "name": "keyword.operator.eventb"
    },
    "tokens_7": {
      "match": "\\b(POW|POW1|circ|dom|mod|not|oftype|or|ran)\\b",
      "name": "keyword.operator.eventb"
    }
  },
  "scopeName": "source.eventb"
}
