{
  "name": "rossi-eventb",
  "displayName": "Rossi Event-B",
  "description": "Rossi language support for Event-B formal modeling with LSP features",
  "version": "0.1.0",
  "publisher": "rossi",
  "license": "MIT OR Apache-2.0",
  "icon": "icons/eventb-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eventb-rossi/rossi"
  },
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "rossi",
    "event-b",
    "formal methods",
    "formal modeling",
    "rodin"
  ],
  "activationEvents": [
    "onLanguage:eventb",
    "onCommand:rossi.importRodinProject",
    "onCommand:rossi.exportCurrentFileToRodinZip",
    "onCommand:rossi.exportWorkspaceToRodinZip",
    "onCommand:rossi.buildCheckedRodinZip",
    "onCommand:rossi.openInRodin",
    "onCommand:rossi.validateCurrentFile",
    "onCommand:rossi.validateWorkspace",
    "onCommand:rossi.convertCurrentFileToUnicode",
    "onCommand:rossi.convertCurrentFileToAscii",
    "onCommand:rossi.checkToolchain",
    "onCommand:rossi.newProject"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "eventb",
        "aliases": [
          "Event-B",
          "eventb"
        ],
        "extensions": [
          ".eventb"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/eventb-icon.svg",
          "dark": "./icons/eventb-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "eventb",
        "scopeName": "source.eventb",
        "path": "./syntaxes/eventb.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "eventb",
        "path": "./snippets/eventb.json"
      }
    ],
    "commands": [
      {
        "command": "rossi.importRodinProject",
        "title": "Import Rodin Project",
        "category": "Rossi"
      },
      {
        "command": "rossi.exportCurrentFileToRodinZip",
        "title": "Export Current File to Rodin ZIP",
        "category": "Rossi"
      },
      {
        "command": "rossi.exportWorkspaceToRodinZip",
        "title": "Export Workspace to Rodin ZIP",
        "category": "Rossi"
      },
      {
        "command": "rossi.buildCheckedRodinZip",
        "title": "Build Checked Rodin ZIP",
        "category": "Rossi"
      },
      {
        "command": "rossi.openInRodin",
        "title": "Open in Rodin",
        "category": "Rossi"
      },
      {
        "command": "rossi.validateCurrentFile",
        "title": "Validate Current File",
        "category": "Rossi"
      },
      {
        "command": "rossi.validateWorkspace",
        "title": "Validate Workspace",
        "category": "Rossi"
      },
      {
        "command": "rossi.convertCurrentFileToUnicode",
        "title": "Convert Current File to Unicode",
        "category": "Rossi"
      },
      {
        "command": "rossi.convertCurrentFileToAscii",
        "title": "Convert Current File to ASCII",
        "category": "Rossi"
      },
      {
        "command": "rossi.checkToolchain",
        "title": "Check Toolchain",
        "category": "Rossi"
      },
      {
        "command": "rossi.newProject",
        "title": "New Event-B Project",
        "category": "Rossi"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rossi.exportCurrentFileToRodinZip",
          "when": "resourceExtname == .eventb",
          "group": "rossi@1"
        },
        {
          "command": "rossi.validateCurrentFile",
          "when": "resourceExtname == .eventb",
          "group": "rossi@2"
        },
        {
          "command": "rossi.convertCurrentFileToUnicode",
          "when": "resourceExtname == .eventb",
          "group": "rossi@3"
        },
        {
          "command": "rossi.convertCurrentFileToAscii",
          "when": "resourceExtname == .eventb",
          "group": "rossi@4"
        },
        {
          "command": "rossi.buildCheckedRodinZip",
          "when": "resourceExtname == .eventb || resourceExtname == .zip || resourceExtname == .buc || resourceExtname == .bum",
          "group": "rossi@5"
        },
        {
          "command": "rossi.buildCheckedRodinZip",
          "when": "explorerResourceIsFolder",
          "group": "rossi@5"
        },
        {
          "command": "rossi.openInRodin",
          "when": "resourceExtname == .eventb",
          "group": "rossi@6"
        },
        {
          "command": "rossi.openInRodin",
          "when": "explorerResourceIsFolder",
          "group": "rossi@6"
        },
        {
          "command": "rossi.importRodinProject",
          "when": "resourceExtname == .zip || resourceExtname == .buc || resourceExtname == .bum",
          "group": "rossi@7"
        },
        {
          "command": "rossi.importRodinProject",
          "when": "explorerResourceIsFolder",
          "group": "rossi@7"
        },
        {
          "command": "rossi.newProject",
          "when": "explorerResourceIsFolder",
          "group": "rossi@8"
        }
      ],
      "editor/context": [
        {
          "command": "rossi.validateCurrentFile",
          "when": "editorLangId == eventb",
          "group": "rossi@1"
        },
        {
          "command": "rossi.convertCurrentFileToUnicode",
          "when": "editorLangId == eventb",
          "group": "rossi@2"
        },
        {
          "command": "rossi.convertCurrentFileToAscii",
          "when": "editorLangId == eventb",
          "group": "rossi@3"
        },
        {
          "command": "rossi.exportCurrentFileToRodinZip",
          "when": "editorLangId == eventb",
          "group": "rossi@4"
        },
        {
          "command": "rossi.openInRodin",
          "when": "editorLangId == eventb",
          "group": "rossi@5"
        }
      ],
      "commandPalette": [
        {
          "command": "rossi.validateCurrentFile",
          "when": "editorLangId == eventb"
        },
        {
          "command": "rossi.convertCurrentFileToUnicode",
          "when": "editorLangId == eventb"
        },
        {
          "command": "rossi.convertCurrentFileToAscii",
          "when": "editorLangId == eventb"
        },
        {
          "command": "rossi.exportCurrentFileToRodinZip",
          "when": "editorLangId == eventb"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rossi.validateCurrentFile",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == eventb && editorTextFocus"
      },
      {
        "command": "rossi.convertCurrentFileToUnicode",
        "key": "ctrl+k u",
        "mac": "cmd+k u",
        "when": "editorLangId == eventb && editorTextFocus"
      },
      {
        "command": "rossi.convertCurrentFileToAscii",
        "key": "ctrl+k a",
        "mac": "cmd+k a",
        "when": "editorLangId == eventb && editorTextFocus"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Rossi",
      "properties": {
        "rossi.tool.path": {
          "type": "string",
          "default": "rossi",
          "description": "Path to the Rossi CLI executable used for import, export, build, validation, and conversion commands."
        },
        "rossi.languageServer.path": {
          "type": "string",
          "default": "rossi-language-server",
          "description": "Path to the Event-B language server executable. If not specified, searches in PATH."
        },
        "rossi.rodin.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Rodin IDE executable, macOS .app bundle, or app name used by the Open in Rodin command. Leave empty to use the platform default."
        },
        "rossi.format.useUnicode": {
          "type": "boolean",
          "default": true,
          "description": "Use Unicode operators (∧, ∨, ⇒, ∈) instead of ASCII (/\\, \\/, =>, :) when formatting."
        },
        "rossi.format.indentation": {
          "type": "string",
          "default": "    ",
          "description": "Indentation string (spaces or tabs) to use when formatting."
        },
        "rossi.format.maxLineLength": {
          "type": "number",
          "default": 100,
          "description": "Maximum line length for future formatter wrapping behavior."
        },
        "rossi.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time diagnostics for syntax errors."
        },
        "rossi.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Reserved for future diagnostic debouncing; diagnostics currently run immediately after typing."
        },
        "rossi.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Event-B code completion."
        },
        "rossi.input.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Convert ASCII to Unicode math symbols as you type. Eager combos (=> ⇒, |-> ↦) and the `\\name` leader (\\and ∧, \\to →, \\nat ℕ). The leader key is `\\`."
        },
        "rossi.input.eager": {
          "type": "boolean",
          "default": true,
          "description": "Eagerly substitute symbolic operator combos (=>, <=>, |->, :=) while typing. When off, only the `\\name` leader converts. Requires rossi.input.enabled."
        },
        "rossi.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "rossi.getStarted",
        "title": "Get Started with Event-B",
        "description": "Set up the Rossi toolchain and create your first Event-B model.",
        "steps": [
          {
            "id": "rossi.getStarted.checkToolchain",
            "title": "Check your toolchain",
            "description": "Confirm the rossi CLI and language server are installed.\n[Check Toolchain](command:rossi.checkToolchain)",
            "media": {
              "markdown": "walkthroughs/check-toolchain.md"
            },
            "completionEvents": [
              "onCommand:rossi.checkToolchain"
            ]
          },
          {
            "id": "rossi.getStarted.createModel",
            "title": "Create your first model",
            "description": "Scaffold a project with a starter .eventb file.\n[New Event-B Project](command:rossi.newProject)",
            "media": {
              "markdown": "walkthroughs/create-model.md"
            },
            "completionEvents": [
              "onCommand:rossi.newProject"
            ]
          },
          {
            "id": "rossi.getStarted.writeEventb",
            "title": "Write Event-B",
            "description": "Edit the .eventb file with snippets, live diagnostics, and formatting.",
            "media": {
              "markdown": "walkthroughs/write-eventb.md"
            },
            "completionEvents": [
              "onLanguage:eventb"
            ]
          },
          {
            "id": "rossi.getStarted.exportRodin",
            "title": "Export to Rodin",
            "description": "Hand the model to the Rodin platform.\n[Open in Rodin](command:rossi.openInRodin)",
            "media": {
              "markdown": "walkthroughs/export-rodin.md"
            },
            "completionEvents": [
              "onCommand:rossi.exportCurrentFileToRodinZip",
              "onCommand:rossi.openInRodin"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle:prod",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --target=node20 --sourcemap",
    "bundle:prod": "npm run bundle -- --minify",
    "watch": "npm run bundle -- --watch",
    "lint": "eslint src --ext ts",
    "test:matcher": "tsc -p ./ && node out/symbolMatcher.test.js",
    "test:region": "tsc -p ./ && node out/validationRegion.test.js",
    "test": "tsc -p ./ && node out/symbolMatcher.test.js && node out/validationRegion.test.js",
    "package": "vsce package",
    "check:vsix": "node scripts/check-vsix.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  }
}
