CONTEXT basic_ctx
CONSTANTS
    min_value max_value default_value
AXIOMS
    @axm1 min_value = 0
    @axm2 max_value = 100
    @axm3 default_value = 50
    @axm4 min_value < max_value
    @axm5 default_value >= min_value
    @axm6 default_value <= max_value
    @thm1 theorem max_value > min_value
END
